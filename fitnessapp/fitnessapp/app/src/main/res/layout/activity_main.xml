<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF2ED"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="90dp">

        <!-- ═══ HEADER ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="12dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="My Progress"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#1B3A2F"
                    android:fontFamily="serif"/>

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thursday, 19 March 2026"
                    android:textSize="13sp"
                    android:textColor="#4A6357"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Avatar -->
            <TextView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:text="🌿"
                android:textSize="20sp"
                android:gravity="center"
                android:background="@drawable/bg_avatar"
                android:elevation="4dp"/>
        </LinearLayout>

        <!-- ═══ WEIGHT PROGRESS CHART CARD ═══ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardChart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#D6E6CC">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Weight Progress"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1B3A2F"
                    android:fontFamily="serif"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Last 8 weeks"
                    android:textSize="12sp"
                    android:textColor="#8FA89A"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="14dp"/>

                <!-- Chart placeholder -->
                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/lineChart"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"/>

                <!-- X-axis labels -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Jan 26"
                        android:textSize="11sp"
                        android:textColor="#8FA89A"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Feb 9"
                        android:textSize="11sp"
                        android:textColor="#8FA89A"
                        android:gravity="center"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Feb 23"
                        android:textSize="11sp"
                        android:textColor="#8FA89A"
                        android:gravity="center"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Mar 9"
                        android:textSize="11sp"
                        android:textColor="#8FA89A"
                        android:gravity="center"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Today"
                        android:textSize="11sp"
                        android:textColor="#8FA89A"
                        android:gravity="end"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══ STATS ROW (Goal / Current / Lost) ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="14dp"
            android:weightSum="3">

            <!-- Goal Weight -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:text="🎯"
                        android:textSize="16sp"
                        android:gravity="center"
                        android:background="@drawable/bg_stat_icon_green"
                        android:layout_marginBottom="10dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="72 kg"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#1B3A2F"
                        android:fontFamily="serif"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Goal"
                        android:textSize="11sp"
                        android:textColor="#8FA89A"
                        android:layout_marginTop="3dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Current Weight -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="3dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:text="⚡"
                        android:textSize="16sp"
                        android:gravity="center"
                        android:background="@drawable/bg_stat_icon_orange"
                        android:layout_marginBottom="10dp"/>

                    <TextView
                        android:id="@+id/tvCurrentWeight"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#1B3A2F"
                        android:fontFamily="serif"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Current"
                        android:textSize="11sp"
                        android:textColor="#8FA89A"
                        android:layout_marginTop="3dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Total Lost -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:text="📉"
                        android:textSize="16sp"
                        android:gravity="center"
                        android:background="@drawable/bg_stat_icon_blue"
                        android:layout_marginBottom="10dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#1B3A2F"
                        android:fontFamily="serif"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Lost"
                        android:textSize="11sp"
                        android:textColor="#8FA89A"
                        android:layout_marginTop="3dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp">

            <Button
                android:id="@+id/btnFood"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="🍎 Nutrition"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/bg_btn_primary"
                android:stateListAnimator="@null"/>

            <Button
                android:id="@+id/btnAddWorkout"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="💪 Workout"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/bg_btn_primary"
                android:stateListAnimator="@null"/>
        </LinearLayout>

        <!-- ═══ BMI CARD ═══ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardBmi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BMI Overview"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1B3A2F"
                    android:fontFamily="serif"/>

                <!-- BMI Value + Badge -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:id="@+id/tvBmiValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:textColor="#1B3A2F"
                        android:fontFamily="serif"/>

                    <TextView
                        android:id="@+id/tvBmiStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#3A9E60"
                        android:background="@drawable/bg_badge_green"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:layout_marginStart="10dp"/>
                </LinearLayout>

                <!-- BMI Gradient Bar -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_bmi_bar"/>

                <!-- BMI Labels -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp">

                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Under"
                        android:textSize="10sp" android:textColor="#8FA89A"/>

                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Normal"
                        android:textSize="10sp" android:textColor="#8FA89A"
                        android:gravity="center"/>

                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Over"
                        android:textSize="10sp" android:textColor="#8FA89A"
                        android:gravity="center"/>

                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Obese"
                        android:textSize="10sp" android:textColor="#8FA89A"
                        android:gravity="end"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══ RECENT LOG SECTION LABEL ═══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RECENT LOG"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#4A6357"
            android:letterSpacing="0.08"
            android:paddingHorizontal="20dp"
            android:paddingBottom="10dp"/>

        <!-- ═══ LOG CARD ═══ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:id="@+id/logContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="6dp">
                <!-- Log items will be added here dynamically -->
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══ LOG BUTTON ═══ -->
        <Button
            android:id="@+id/btnLogWeight"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="16dp"
            android:text="+ Log Today's Weight"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_btn_primary"
            android:stateListAnimator="@null"
            android:elevation="8dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>