<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvFoodName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chicken Breast"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#1B3A2F"/>

        <TextView
            android:id="@+id/tvFoodMacros"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="P: 30g  C: 0g  F: 3g"
            android:textSize="12sp"
            android:textColor="#8FA89A"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvFoodCalories"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="165 kcal"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#3D7A5F"
        android:layout_marginEnd="12dp"/>

    <ImageView
        android:id="@+id/btnDeleteFood"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@android:drawable/ic_delete"
        android:tint="#E07B6A"/>
</LinearLayout>