<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_dialog">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Food"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#1B3A2F"
        android:fontFamily="serif"
        android:layout_marginBottom="20dp"/>

    <EditText
        android:id="@+id/etFoodName"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Food name (e.g. Rice, Chicken)"
        android:textSize="14sp"
        android:background="@drawable/bg_input"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="12dp"
        android:inputType="text"/>

    <EditText
        android:id="@+id/etCalories"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Calories (kcal)"
        android:textSize="14sp"
        android:background="@drawable/bg_input"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="12dp"
        android:inputType="numberDecimal"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3"
        android:layout_marginBottom="20dp">

        <EditText
            android:id="@+id/etProtein"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:hint="Protein (g)"
            android:textSize="13sp"
            android:background="@drawable/bg_input"
            android:paddingHorizontal="12dp"
            android:inputType="numberDecimal"/>

        <EditText
            android:id="@+id/etCarbs"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="3dp"
            android:hint="Carbs (g)"
            android:textSize="13sp"
            android:background="@drawable/bg_input"
            android:paddingHorizontal="12dp"
            android:inputType="numberDecimal"/>

        <EditText
            android:id="@+id/etFats"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:hint="Fats (g)"
            android:textSize="13sp"
            android:background="@drawable/bg_input"
            android:paddingHorizontal="12dp"
            android:inputType="numberDecimal"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Cancel"
            android:textColor="#4A6357"
            android:background="@drawable/bg_btn_outline"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btnSaveFood"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Add"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_btn_primary"
            android:stateListAnimator="@null"/>
    </LinearLayout>
</LinearLayout>